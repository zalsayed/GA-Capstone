# ─────────────────────────────────────────────────────────────────────────────
# Req2Defect — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set ONE provider key and update LLM_PROVIDER to match.

# ① Claude (Anthropic) — paid, highest quality
#    Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ② Gemini — FREE tier (1,500 req/day on Flash)
#    Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ③ Groq — FREE (14,400 req/day on Llama 3.3 70B) ← best free option
#    Get key: https://console.groq.com  (no credit card needed)
GROQ_API_KEY=

# ④ OpenRouter — FREE models available (Llama, Mistral, Gemma, DeepSeek)
#    Get key: https://openrouter.ai/keys  (no credit card needed)
OPENROUTER_API_KEY=

# ── Active provider ───────────────────────────────────────────────────────────
# Options: Claude (Anthropic) | Gemini | Groq (free) | OpenRouter (free) | Ollama (local)
LLM_PROVIDER=Groq (free)

# ── Model selection ───────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SEC=120

# ── Ollama (local, completely free, no internet needed) ───────────────────────
#    Install: https://ollama.com  then: ollama pull llama3
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── App Settings ──────────────────────────────────────────────────────────────
APP_TITLE=Req2Defect
APP_ENV=development
LOG_LEVEL=INFO
DB_PATH=data/req2defect.db

# ── Authentication ────────────────────────────────────────────────────────────
AUTH_ENABLED=false
# Generate hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
AUTH_PASSWORD_HASH=

# ── Jira Integration (optional) ──────────────────────────────────────────────
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PROJ

# ── Test Execution ────────────────────────────────────────────────────────────
TEST_BASE_URL=http://localhost:3000
PLAYWRIGHT_HEADLESS=true
APPIUM_URL=http://localhost:4723
